{
  "name": "agentos-app",
  "version": "0.1.0",
  "description": "A governed assistant runtime with a mission kernel, operator web console, and bounded worker execution.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "test": "vitest run",
    "test:postgres": "vitest run test/postgres.failure-drills.test.ts",
    "test:watch": "vitest",
    "start:web": "node dist/src/main-web.js",
    "start:worker": "node dist/src/main-worker.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.3.0",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
